-- basic_test.mesa
-- Prueba minimalista de eco de teclado (v4.0.3)

LOAD_ADDR = 0x7C00
IMAGEN = "mesa-os/basic.img"

asm = x86_nuevo()
iniciar_boot(asm)
modo_video(asm, 0x03)

-- Mensaje inicial simple
cadena(asm, "msg", "MesaOS v4.0 Active. Escribe algo: ")
apuntar(asm, LOAD_ADDR, "msg")
llamar(asm, "print_str")

-- Bucle de eco puro (Sin prompts intermedios)
etiqueta(asm, "bucle")

-- Leer tecla (int 16h, ah=0)
x86_bytes(asm, [0xB4, 0x00, 0xCD, 0x16])

-- Eco de tecla (int 10h, ah=0Eh)
x86_bytes(asm, [0xB4, 0x0E, 0xBB, 0x07, 0x00, 0xCD, 0x10])

-- Volver al bucle
jmp_a(asm, "bucle")

-- Routines
insertar_print_str(asm)

-- Build
decir("⚙️ Compilando test básico...")
codigo = compilar(asm)
boot = bootsector(codigo)
crear_directorio("mesa-os")
archivo_escribir_bytes(IMAGEN, boot)

decir("🚀 Test listo en " + IMAGEN)
lanzar_qemu(IMAGEN)
