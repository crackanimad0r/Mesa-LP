-- ============================================
-- Tests Básicos de Mesa Language
-- ============================================

prueba "suma básica" {
    verificar(1 + 1 == 2)
    verificar(10 + 20 == 30)
    verificar(-5 + 5 == 0)
}

test "subtraction" {
    check(10 - 5 == 5)
    check(0 - 1 == -1)
}

prueba "multiplicación" {
    verificar(3 * 4 == 12)
    verificar(0 * 100 == 0)
    verificar(-2 * 3 == -6)
}

test "division" {
    check(10 / 2 == 5)
    check(15 / 3 == 5)
}

prueba "comparaciones" {
    verificar(5 > 3)
    verificar(3 < 5)
    verificar(5 >= 5)
    verificar(5 <= 5)
    verificar(5 == 5)
    verificar(5 != 3)
}

test "boolean logic" {
    check(true and true)
    check(true or false)
    check(not false)
}

prueba "strings" {
    texto = "Hola"
    verificar(len(texto) == 4)
}

test "lists" {
    lista = [1, 2, 3]
    check(len(lista) == 3)
    check(lista[0] == 1)
    check(lista[2] == 3)
}

inicio {
    decir("✅ Tests básicos completados")
}
