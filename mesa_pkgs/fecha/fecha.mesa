-- Paquete: fecha v1.1.0
-- Utilidades de fecha y tiempo

funcion ahora() {
    dar tiempo()
}

funcion dias_hasta(timestamp_futuro) {
    diferencia = timestamp_futuro - tiempo()
    dar entero(diferencia / 86400)
}

funcion es_bisiesto(anio) {
    dar (anio % 4 == 0 y anio % 100 != 0) o (anio % 400 == 0)
}

funcion dias_en_mes(mes, anio) {
    dias = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    si mes == 2 y es_bisiesto(anio) {
        dar 29
    }
    dar dias[mes - 1]
}
