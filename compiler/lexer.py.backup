            'str': TokenType.STR,
            'char': TokenType.CHAR,
            'bool': TokenType.BOOL,
            'list': TokenType.LIST,
            'map': TokenType.MAP,
            'set': TokenType.SET,
            'tuple': TokenType.TUPLE,
            'array': TokenType.ARRAY,
            'vec': TokenType.VEC,
        }
    
    # ========== UTILIDADES ==========
    
    def current_char(self) -> Optional[str]:
        """Obtiene el carácter actual"""
        if self.pos >= len(self.source):
            return None
        return self.source[self.pos]
    
    def peek(self, offset: int = 1) -> Optional[str]:
        """Mira adelante sin avanzar"""
        pos = self.pos + offset
        if pos >= len(self.source):
            return None
        return self.source[pos]
    
    def advance(self) -> Optional[str]:
        """Avanza una posición"""
        if self.pos < len(self.source):
            char = self.source[self.pos]
            if char == '\n':
                self.line += 1
                self.column = 1
            else:
                self.column += 1
            self.pos += 1
            return char
        return None
    
    def skip_whitespace(self):
        """Salta espacios en blanco (excepto newline)"""
        while self.current_char() and self.current_char() in ' \t\r':
            self.advance()
    
    def make_token(self, token_type: TokenType, value: any, length: int = 1) -> Token:
        """Crea un token"""
        return Token(token_type, value, self.line, self.column - length, length)
    
    def error(self, message: str):
        """Lanza un error de lexer"""
        raise LexerError(message, self.line, self.column)
    
    # ========== COMENTARIOS ==========
    
    def skip_line_comment(self):
        """Salta comentarios de línea: -- comentario"""
        if self.current_char() == '-' and self.peek() == '-':
            # Verificar si es doc comment: ---
            if self.peek(2) == '-':
                return self.read_doc_comment()
            
            while self.current_char() and self.current_char() != '\n':
                self.advance()
    
    def read_doc_comment(self) -> Token:
        """Lee comentario de documentación: --- comentario"""
        start_col = self.column
        self.advance()  # -
        self.advance()  # -
        self.advance()  # -
        
        comment = ''
        while self.current_char() and self.current_char() != '\n':
            comment += self.current_char()
            self.advance()
        
        return self.make_token(TokenType.DOC_COMMENT, comment.strip(), len(comment) + 3)
    
    def skip_multiline_comment(self):
        """Salta comentarios multilínea: /* comentario */"""
        if self.current_char() == '/' and self.peek() == '*':
            self.advance()  # /
            self.advance()  # *
            
            depth = 1
            while depth > 0 and self.current_char():
                if self.current_char() == '/' and self.peek() == '*':
                    self.advance()
                    self.advance()
                    depth += 1
                elif self.current_char() == '*' and self.peek() == '/':
                    self.advance()
                    self.advance()
                    depth -= 1
                else:
                    self.advance()
            
            if depth > 0:
                self.error("Comentario multilínea sin cerrar")
    
    # ========== NÚMEROS ==========
    
    def read_number(self) -> Token:
        """
        Lee números en varios formatos:
        - Decimal: 123, 3.14
        - Hexadecimal: 0xFF, 0xDEADBEEF
        - Binario: 0b1010, 0b11110000
        - Octal: 0o777, 0o644
        - Con separadores: 1_000_000
        - Científico: 1.5e10, 2.3e-5
        """
        start_col = self.column
        num_str = ''
        token_type = TokenType.NUMBER
        
        # Números hexadecimales
        if self.current_char() == '0' and self.peek() and self.peek().lower() == 'x':
            token_type = TokenType.HEX_NUMBER
            self.advance()  # 0
            self.advance()  # x
            while self.current_char() and (self.current_char().isdigit() or 
                                          self.current_char().lower() in 'abcdef' or 
                                          self.current_char() == '_'):
                if self.current_char() != '_':
                    num_str += self.current_char()
                self.advance()
            
            if not num_str:
                self.error("Número hexadecimal inválido")
            
            value = int(num_str, 16)
            return self.make_token(token_type, value, len(num_str) + 2)
        
        # Números binarios
        if self.current_char() == '0' and self.peek() and self.peek().lower() == 'b':
            token_type = TokenType.BIN_NUMBER
            self.advance()  # 0
            self.advance()  # b
            while self.current_char() and (self.current_char() in '01' or self.current_char() == '_'):
                if self.current_char() != '_':
                    num_str += self.current_char()
                self.advance()
            
            if not num_str:
                self.error("Número binario inválido")
            
            value = int(num_str, 2)
            return self.make_token(token_type, value, len(num_str) + 2)
        
        # Números octales
        if self.current_char() == '0' and self.peek() and self.peek().lower() == 'o':
            token_type = TokenType.OCT_NUMBER
            self.advance()  # 0
            self.advance()  # o
            while self.current_char() and (self.current_char() in '01234567' or self.current_char() == '_'):
                if self.current_char() != '_':
                    num_str += self.current_char()
                self.advance()
            
            if not num_str:
                self.error("Número octal inválido")
            
            value = int(num_str, 8)
            return self.make_token(token_type, value, len(num_str) + 2)
        
        # Números decimales
        has_dot = False
        has_exp = False
        
        while self.current_char() and (self.current_char().isdigit() or 
                                      self.current_char() in '._eE'):
            if self.current_char() == '_':
                self.advance()
                continue
            
            if self.current_char() == '.':
                if has_dot or has_exp:
                    break
                if self.peek() and not self.peek().isdigit():
                    break  # Es un operador .
                has_dot = True
                num_str += self.current_char()
                self.advance()
            
            elif self.current_char() in 'eE':
                if has_exp:
                    self.error("Múltiples exponentes en número")
                has_exp = True
                num_str += self.current_char()
                self.advance()
                
                if self.current_char() in '+-':
                    num_str += self.current_char()
                    self.advance()
            
            else:
                num_str += self.current_char()
                self.advance()
        
        if not num_str or num_str in '.eE':
            self.error(f"Número inválido: {num_str}")
        
        try:
            if has_dot or has_exp:
                value = float(num_str)
            else:
                value = int(num_str)
        except ValueError:
            self.error(f"No se puede convertir '{num_str}' a número")
        
        return self.make_token(token_type, value, len(num_str))
    
    # ========== STRINGS ==========
    
    def read_string(self, quote: str) -> Token:
        rrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrrr"""
        Lee strings con soporte para:
        - Strings simples: "texto", 'texto'
        - Strings multilínea: '''texto'''
        - Strings con formato: f"Hola {nombre}"
        - Raw strings: r"C:\ruta\sin\escape"
        - Secuencias de escape: \n, \t, \xFF, \u{1F4A9}
        """
        start_col = self.column
        is_format = False
        is_raw = False
        is_multiline = False
        
        # Verificar prefijos
        if quote == '"' or quote == "'":
            # Verificar si es multilínea
            if self.peek() == quote and self.peek(2) == quote:
                is_multiline = True
                self.advance()  # primera comilla
                self.advance()  # segunda comilla
                self.advance()  # tercera comilla
        
        string_value = ''
        escape_sequences = {
            'n': '\n',
            't': '\t',
            'r': '\r',
            '\\': '\\',
            '"': '"',
            "'": "'",
            '0': '\0',
        }
        
        while self.current_char():
            # Fin del string
            if is_multiline:
                if (self.current_char() == quote and 
                    self.peek() == quote and 
                    self.peek(2) == quote):
                    self.advance()
                    self.advance()
                    self.advance()
                    break
            else:
                if self.current_char() == quote:
                    self.advance()
                    break
            
            # Secuencias de escape
            if self.current_char() == '\\' and not is_raw:
                self.advance()
                escape_char = self.current_char()
                
                if escape_char in escape_sequences:
                    string_value += escape_sequences[escape_char]
                    self.advance()
                
                elif escape_char == 'x':  # \xFF
                    self.advance()
                    hex_chars = ''
                    for _ in range(2):
                        if self.current_char() and self.current_char() in '0123456789ABCDEFabcdef':
                            hex_chars += self.current_char()
                            self.advance()
                    if len(hex_chars) == 2:
                        string_value += chr(int(hex_chars, 16))
                    else:
                        self.error("Secuencia de escape hexadecimal inválida")
                
                elif escape_char == 'u':  # \u{1F4A9}
                    if self.peek() == '{':
                        self.advance()  # u
                        self.advance()  # {
                        unicode_chars = ''
                        while self.current_char() and self.current_char() != '}':
                            unicode_chars += self.current_char()
                            self.advance()
                        if self.current_char() == '}':
                            self.advance()
                            try:
                                string_value += chr(int(unicode_chars, 16))
                            except ValueError:
                                self.error(f"Código Unicode inválido: {unicode_chars}")
                        else:
                            self.error("Secuencia Unicode sin cerrar")
                    else:
                        self.error("Formato Unicode inválido, usa \\u{XXXX}")
                
                else:
                    string_value += escape_char
                    self.advance()
            
            else:
                string_value += self.current_char()
                self.advance()
        
        else:
            self.error("String sin cerrar")
        
        token_type = TokenType.MULTILINE_STRING if is_multiline else TokenType.STRING_LITERAL
        return self.make_token(token_type, string_value, len(string_value))
    
    def read_format_string(self) -> Token:
        """Lee format string: f"Hola {nombre}" """
        start_col = self.column
        self.advance()  # f
        
        if self.current_char() not in '"\'':
            self.error("Se esperaba comilla después de 'f'")
        
        quote = self.current_char()
        self.advance()
        
        # TODO: Parsear interpolaciones {expr}
        # Por ahora, tratarlo como string normal
        return self.read_string(quote)
    
    # ========== IDENTIFICADORES ==========
    
    def read_identifier(self) -> Token:
        """
        Lee identificadores y palabras clave
        Soporta Unicode: variable_ñ, año, François
        """
        start_col = self.column
        identifier = ''
        
        # Primer carácter: letra, _, o unicode
        if not (self.current_char().isalpha() or 
                self.current_char() == '_' or 
                ord(self.current_char()) > 127):
            self.error(f"Identificador inválido: {self.current_char()}")
        
        while self.current_char() and (self.current_char().isalnum() or 
                                      self.current_char() in '_ñáéíóúüÁÉÍÓÚÜ' or
                                      ord(self.current_char()) > 127):
            identifier += self.current_char()
            self.advance()
        
        # Verificar si es palabra clave
        token_type = self.keywords.get(identifier, TokenType.IDENTIFIER)
        
        # Verificar si es tipo (empieza con mayúscula)
        if token_type == TokenType.IDENTIFIER and identifier[0].isupper():
            token_type = TokenType.TYPE_IDENTIFIER
        
        return self.make_token(token_type, identifier, len(identifier))
    
    # ========== OPERADORES ==========
    
    def read_operator(self) -> Optional[Token]:
        """Lee operadores complejos"""
        char = self.current_char()
        start_col = self.column
        
        # Operadores de 3 caracteres
        three_char = char + (self.peek() or '') + (self.peek(2) or '')
        if three_char == '<=>':
            self.advance()
            self.advance()
            self.advance()
            return self.make_token(TokenType.SPACESHIP, '<=>', 3)
        elif three_char == '...':
            self.advance()
            self.advance()
            self.advance()
            return self.make_token(TokenType.SPREAD, '...', 3)
        elif three_char == '**=':
            self.advance()
            self.advance()
            self.advance()
            return self.make_token(TokenType.POWER_ASSIGN, '**=', 3)
        elif three_char == '<<=':
            self.advance()
            self.advance()
            self.advance()
            return self.make_token(TokenType.LSHIFT_ASSIGN, '<<=', 3)
        elif three_char == '>>=':
            self.advance()
            self.advance()
            self.advance()
            return self.make_token(TokenType.RSHIFT_ASSIGN, '>>=', 3)
        
        # Operadores de 2 caracteres
        two_char = char + (self.peek() or '')
        two_char_ops = {
            '==': TokenType.EQUAL,
            '!=': TokenType.NOT_EQUAL,
            '<=': TokenType.LESS_EQUAL,
            '>=': TokenType.GREATER_EQUAL,
            '+=': TokenType.PLUS_ASSIGN,
            '-=': TokenType.MINUS_ASSIGN,
            '*=': TokenType.MULTIPLY_ASSIGN,
            '/=': TokenType.DIVIDE_ASSIGN,
            '%=': TokenType.MODULO_ASSIGN,
            '&=': TokenType.AND_ASSIGN,
            '|=': TokenType.OR_ASSIGN,
            '^=': TokenType.XOR_ASSIGN,
            '**': TokenType.POWER,
            '//': TokenType.FLOOR_DIV,
            '<<': TokenType.LSHIFT,
            '>>': TokenType.RSHIFT,
            '->': TokenType.ARROW,
            '=>': TokenType.FAT_ARROW,
            '::': TokenType.DOUBLE_COLON,
            '..': TokenType.RANGE,
            '|>': TokenType.PIPELINE,
        }
        
        if two_char in two_char_ops:
            self.advance()
            self.advance()
            return self.make_token(two_char_ops[two_char], two_char, 2)
        
        # Operadores de 1 carácter
        one_char_ops = {
            '+': TokenType.PLUS,
            '-': TokenType.MINUS,
            '*': TokenType.MULTIPLY,
            '/': TokenType.DIVIDE,
            '%': TokenType.MODULO,
            '<': TokenType.LESS,
            '>': TokenType.GREATER,
            '=': TokenType.ASSIGN,
            '&': TokenType.BIT_AND,
            '|': TokenType.BIT_OR,
            '^': TokenType.BIT_XOR,
            '~': TokenType.BIT_NOT,
            '?': TokenType.QUESTION,
            '!': TokenType.EXCLAMATION,
            '@': TokenType.AT,
            '#': TokenType.HASH,
            '$': TokenType.DOLLAR,
        }
        
        if char in one_char_ops:
            self.advance()
            return self.make_token(one_char_ops[char], char, 1)
        
        return None
    
    # ========== DELIMITADORES ==========
    
    def read_delimiter(self) -> Optional[Token]:
        """Lee delimitadores"""
        char = self.current_char()
        start_col = self.column
        
        delimiters = {
            '(': TokenType.LPAREN,
            ')': TokenType.RPAREN,
            '{': TokenType.LBRACE,
            '}': TokenType.RBRACE,
            '[': TokenType.LBRACKET,
            ']': TokenType.RBRACKET,
            ',': TokenType.COMMA,
            '.': TokenType.DOT,
            ':': TokenType.COLON,
            ';': TokenType.SEMICOLON,
            '\\': TokenType.BACKSLASH,
        }
        
        if char in delimiters:
            self.advance()
            return self.make_token(delimiters[char], char, 1)
        
        return None
    
    # ========== DIRECTIVAS Y MACROS ==========
    
    def read_directive(self) -> Token:
        """Lee directivas de preprocesador: #include, #define"""
        start_col = self.column
        self.advance()  # #
        
        directive = ''
        while self.current_char() and (self.current_char().isalnum() or self.current_char() == '_'):
            directive += self.current_char()
            self.advance()
        
        return self.make_token(TokenType.DIRECTIVE, directive, len(directive) + 1)
    
    def read_macro(self) -> Token:
        """Lee invocaciones de macros: println!(), vec![]"""
        start_col = self.column
        macro_name = ''
        
        while self.current_char() and (self.current_char().isalnum() or self.current_char() == '_'):
            macro_name += self.current_char()
            self.advance()
        
        if self.current_char() == '!':
            self.advance()
            return self.make_token(TokenType.MACRO, macro_name, len(macro_name) + 1)
        
        # No es macro, retroceder
        for _ in range(len(macro_name)):
            self.pos -= 1
            self.column -= 1
        
        return None
    
    # ========== TOKENIZACIÓN PRINCIPAL ==========
    
    def tokenize(self) -> List[Token]:
        """Tokeniza todo el código fuente"""
        while self.current_char():
            # Espacios en blanco
            self.skip_whitespace()
            
            if not self.current_char():
                break
            
            # Newline
            if self.current_char() == '\n':
                self.tokens.append(self.make_token(TokenType.NEWLINE, '\n', 1))
                self.advance()
                continue
            
            # Comentarios de línea
            if self.current_char() == '-' and self.peek() == '-':
                self.skip_line_comment()
                continue
            
            # Comentarios multilínea
            if self.current_char() == '/' and self.peek() == '*':
                self.skip_multiline_comment()
                continue
            
            # Números
            if self.current_char().isdigit():
                self.tokens.append(self.read_number())
                continue
            
            # Strings
            if self.current_char() in '"\'':
                quote = self.current_char()
                self.advance()
                self.tokens.append(self.read_string(quote))
                continue
            
            # Format strings
            if self.current_char() == 'f' and self.peek() in '"\'':
                self.tokens.append(self.read_format_string())
                continue
            
            # Raw strings
            if self.current_char() == 'r' and self.peek() in '"\'':
                self.advance()  # r
                quote = self.current_char()
                self.advance()
                # TODO: implementar raw string
                self.tokens.append(self.read_string(quote))
                continue
            
            # Directivas
            if self.current_char() == '#':
                self.tokens.append(self.read_directive())
                continue
            
            # Identificadores y palabras clave
            if self.current_char().isalpha() or self.current_char() == '_' or ord(self.current_char()) > 127:
                # Verificar si es macro
                saved_pos = self.pos
                saved_line = self.line
                saved_col = self.column
                
                macro_token = self.read_macro()
                if macro_token:
                    self.tokens.append(macro_token)
                    continue
                
                # Restaurar posición
                self.pos = saved_pos
                self.line = saved_line
                self.column = saved_col
                
                self.tokens.append(self.read_identifier())
                continue
            
            # Operadores
            op_token = self.read_operator()
            if op_token:
                self.tokens.append(op_token)
                continue
            
            # Delimitadores
            delim_token = self.read_delimiter()
            if delim_token:
                self.tokens.append(delim_token)
                continue
            
            # Carácter desconocido
            self.error(f"Carácter inesperado: '{self.current_char()}'")
        
        # EOF
        self.tokens.append(self.make_token(TokenType.EOF, None, 0))
        return self.tokens
    
    def tokenize_with_debug(self) -> List[Token]:
        """Tokeniza con información de depuración"""
        tokens = self.tokenize()
        
        print(f"Total de tokens: {len(tokens)}")
        print("\n--- TOKENS ---")
        for i, token in enumerate(tokens):
            if token.type != TokenType.EOF:
                print(f"{i:4d}. {token}")
        
        return tokens


# ========== UTILIDADES PÚBLICAS ==========

def tokenize_file(filepath: str) -> List[Token]:
    """Tokeniza un archivo"""
    with open(filepath, 'r', encoding='utf-8') as f:
        source = f.read()
    
    lexer = Lexer(source)
    return lexer.tokenize()


def tokenize_string(source: str, debug: bool = False) -> List[Token]:
    """Tokeniza una cadena"""
    lexer = Lexer(source)
    if debug:
        return lexer.tokenize_with_debug()
    return lexer.tokenize()


# ========== TESTING ==========

if __name__ == '__main__':
    # Código de prueba
    test_code = """
    -- Código de prueba Mesa
    inicio {
        x = 42
        nombre = "Mesa"
        lista = [1, 2, 3, 4, 5]
        
        función saludar(nombre) {
            decir("Hola {nombre}")
        }
        
        para i en 0..10 {
            say("Número: {i}")
        }
    }
    """
    
    try:
        tokens = tokenize_string(test_code, debug=True)
    except LexerError as e:
        print(f"\n❌ {e}")
        sys.exit(1)