@dataclass
class Token:
    """Representa un token con toda su información"""
    type: TokenType
    value: any
    line: int
    column: int
    length: int = 0
    
    def __repr__(self):
        return f"Token({self.type.name}, {repr(self.value)}, L{self.line}:C{self.column})"


class LexerError(Exception):
    """Error del lexer con información detallada"""
    def __init__(self, message: str, line: int, column: int):
        self.message = message
        self.line = line
        self.column = column
        super().__init__(f"Error en L{line}:C{column}: {message}")


class Lexer:
    """
    Analizador léxico completo para Mesa Language
    Soporta:
    - Sintaxis bilingüe (Español/English)
    - Números en múltiples bases (bin, oct, dec, hex)
    - Strings multilínea y con formato
    - Comentarios de línea y multilínea
    - Operadores avanzados
    - Indentación opcional (como Python)
    - Macros y directivas
    """
    
    def __init__(self, source: str, use_indentation: bool = False):
        self.source = source
        self.use_indentation = use_indentation
        self.pos = 0
        self.line = 1
        self.column = 1
        self.tokens: List[Token] = []
        self.indent_stack = [0]  # Para manejar indentación
        
        # Mapeo completo de palabras clave bilingües
        self.keywords: Dict[str, TokenType] = {
            # Control de flujo - Español
            'inicio': TokenType.INICIO,
            'fin': TokenType.FIN,
            'función': TokenType.FUNCION,
            'fn': TokenType.FUNCION,
            'dar': TokenType.DAR,
            'retornar': TokenType.RETORNAR,
            'si': TokenType.SI,
            'además': TokenType.ADEMAS,
            'sino': TokenType.SINO,
            'entonces': TokenType.ENTONCES,
            'para': TokenType.PARA,
            'mientras': TokenType.MIENTRAS,
            'repetir': TokenType.REPETIR,
            'bucle': TokenType.BUCLE,
            'parar': TokenType.PARAR,
            'continuar': TokenType.CONTINUAR,
            'saltar': TokenType.SALTAR,
            'coincidir': TokenType.COINCIDIR,
            'caso': TokenType.CASO,
            
            # Control de flujo - English
            'start': TokenType.START,
            'end': TokenType.END,
            'function': TokenType.FUNCTION,
            'give': TokenType.GIVE,
            'return': TokenType.RETURN,
            'if': TokenType.IF,
            'also': TokenType.ALSO,
            'elif': TokenType.ELIF,
            'else': TokenType.ELSE,
            'then': TokenType.THEN,
            'for': TokenType.FOR,
            'while': TokenType.WHILE,
            'repeat': TokenType.REPEAT,
            'loop': TokenType.LOOP,
            'break': TokenType.BREAK,
            'continue': TokenType.CONTINUE,
            'skip': TokenType.SKIP,
            'match': TokenType.MATCH,
            'case': TokenType.CASE,
            
            # Estructuras - Español
            'forma': TokenType.FORMA,
            'clase': TokenType.CLASE,
            'estructura': TokenType.ESTRUCTURA,
            'enumerar': TokenType.ENUMERAR,
            'rasgo': TokenType.RASGO,
            'interfaz': TokenType.INTERFAZ,
            'aplicar': TokenType.APLICAR,
            'implementar': TokenType.IMPLEMENTAR,
            'extender': TokenType.EXTENDER,
            'heredar': TokenType.HEREDAR,
            
            # Estructuras - English
            'shape': TokenType.SHAPE,
            'class': TokenType.CLASS,
            'struct': TokenType.STRUCT,
            'enum': TokenType.ENUM,
            'trait': TokenType.TRAIT,
            'interface': TokenType.INTERFACE,
            'apply': TokenType.APPLY,
