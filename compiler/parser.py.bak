from .lexer import Token, TokenType, Lexer
from .ast_nodes import *
from typing import List, Optional

class Parser:
    def __init__(self, tokens: List[Token]):
        self.tokens = tokens
        self.pos = 0
        self.current_token = self.tokens[0] if tokens else None
    
    def advance(self):
        self.pos += 1
        if self.pos < len(self.tokens):
            self.current_token = self.tokens[self.pos]
        else:
            self.current_token = None
    
    def peek(self, offset=1):
        pos = self.pos + offset
        if pos < len(self.tokens):
            return self.tokens[pos]
        return None
    
    def skip_newlines(self):
        while self.current_token and self.current_token.type == TokenType.NEWLINE:
            self.advance()
    
    def expect(self, *token_types):
        self.skip_newlines()
        if self.current_token and self.current_token.type in token_types:
            token = self.current_token
            self.advance()
            return token
        expected = ' or '.join([t.name for t in token_types])
        raise SyntaxError(f"Se esperaba {expected}, se encontró {self.current_token.type.name if self.current_token else 'EOF'}")
    
    def parse(self) -> Program:
        statements = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.EOF:
            stmt = self.parse_statement()
            if stmt:
                statements.append(stmt)
            self.skip_newlines()
        
        return Program(statements)
    
    def parse_statement(self):
        self.skip_newlines()
        
        if not self.current_token or self.current_token.type == TokenType.EOF:
            return None
        
        # inicio / start
        if self.current_token.type in (TokenType.INICIO, TokenType.START):
            return self.parse_start_block()
        
        # medio / mid
        if self.current_token.type in (TokenType.MEDIO, TokenType.MID):
            return self.parse_layer_block('mid')
        
        # bajo / low
        if self.current_token.type in (TokenType.BAJO, TokenType.LOW):
            return self.parse_layer_block('low')
        
        # función / function
        if self.current_token.type in (TokenType.FUNCION, TokenType.FUNCTION):
            return self.parse_function()
        
        # forma / shape
        if self.current_token.type in (TokenType.FORMA, TokenType.SHAPE):
            return self.parse_shape()
        
        # si / if
        if self.current_token.type in (TokenType.SI, TokenType.IF):
            return self.parse_if()
        
        # mientras / while
        if self.current_token.type in (TokenType.MIENTRAS, TokenType.WHILE):
            return self.parse_while()
        
        # para / for
        if self.current_token.type in (TokenType.PARA, TokenType.FOR):
            return self.parse_for()
        
        # repetir / repeat
        if self.current_token.type in (TokenType.REPETIR, TokenType.REPEAT):
            return self.parse_repeat()
        
        # bucle / loop
        if self.current_token.type in (TokenType.BUCLE, TokenType.LOOP):
            return self.parse_loop()
        
        # dar / give (return)
        if self.current_token.type in (TokenType.DAR, TokenType.GIVE):
            return self.parse_return()
        
        # parar / stop (break)
        if self.current_token.type in (TokenType.PARAR, TokenType.STOP):
            self.advance()
            return Break()
        
        # saltar / skip (continue)
        if self.current_token.type in (TokenType.SALTAR, TokenType.SKIP):
            self.advance()
            return Continue()
        
        # coincidir / match
        if self.current_token.type in (TokenType.COINCIDIR, TokenType.MATCH):
            return self.parse_match()
        
        # intentar / try
        if self.current_token.type in (TokenType.INTENTAR, TokenType.TRY):
            return self.parse_try()
        
        # Asignación o expresión
        return self.parse_assignment_or_expression()
    
    def parse_start_block(self):
        self.expect(TokenType.INICIO, TokenType.START)
        self.expect(TokenType.LBRACE)
        
        statements = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                statements.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        return Program(statements)
    
    def parse_layer_block(self, layer):
        self.advance()  # skip 'mid' or 'low'
        self.expect(TokenType.LBRACE)
        
        statements = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                statements.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        return LayerBlock(layer, statements)
    
    def parse_function(self):
        is_public = False
        if self.current_token.type in (TokenType.PUBLICO, TokenType.PUBLIC):
            is_public = True
            self.advance()
        
        self.expect(TokenType.FUNCION, TokenType.FUNCTION)
        name = self.expect(TokenType.IDENTIFIER).value
        
        self.expect(TokenType.LPAREN)
        params = []
        
        while self.current_token and self.current_token.type != TokenType.RPAREN:
            param_name = self.expect(TokenType.IDENTIFIER).value
            type_annotation = None
            
            if self.current_token and self.current_token.type == TokenType.COLON:
                self.advance()
                type_annotation = self.parse_type()
            
            params.append((param_name, type_annotation))
            
            if self.current_token and self.current_token.type == TokenType.COMMA:
                self.advance()
        
        self.expect(TokenType.RPAREN)
        
        return_type = None
        if self.current_token and self.current_token.type == TokenType.ARROW:
            self.advance()
            
            # Función inline de una línea
            if self.current_token.type != TokenType.LBRACE:
                expr = self.parse_expression()
                return FunctionDef(name, params, [Return(expr)], return_type, is_public)
            
            return_type = self.parse_type() if self.current_token.type == TokenType.IDENTIFIER else None
        
        self.expect(TokenType.LBRACE)
        
        body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return FunctionDef(name, params, body, return_type, is_public)
    
    def parse_shape(self):
        is_public = False
        if self.current_token.type in (TokenType.PUBLICO, TokenType.PUBLIC):
            is_public = True
            self.advance()
        
        self.expect(TokenType.FORMA, TokenType.SHAPE)
        name = self.expect(TokenType.IDENTIFIER).value
        
        self.expect(TokenType.LBRACE)
        
        fields = []
        methods = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            if self.current_token.type in (TokenType.FUNCION, TokenType.FUNCTION):
                methods.append(self.parse_function())
            else:
                # Field
                field_name = self.expect(TokenType.IDENTIFIER).value
                self.expect(TokenType.COLON)
                field_type = self.parse_type()
                
                default_value = None
                if self.current_token and self.current_token.type == TokenType.ASSIGN:
                    self.advance()
                    default_value = self.parse_expression()
                
                fields.append((field_name, field_type, default_value))
            
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return ShapeDef(name, fields, methods, is_public)
    
    def parse_if(self):
        self.expect(TokenType.SI, TokenType.IF)
        condition = self.parse_expression()
        self.expect(TokenType.LBRACE)
        
        then_body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                then_body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        elif_parts = []
        else_body = None
        
        while self.current_token and self.current_token.type in (TokenType.ADEMAS, TokenType.ALSO):
            self.advance()
            elif_condition = self.parse_expression()
            self.expect(TokenType.LBRACE)
            
            elif_body = []
            self.skip_newlines()
            
            while self.current_token and self.current_token.type != TokenType.RBRACE:
                stmt = self.parse_statement()
                if stmt:
                    elif_body.append(stmt)
                self.skip_newlines()
            
            self.expect(TokenType.RBRACE)
            elif_parts.append((elif_condition, elif_body))
        
        if self.current_token and self.current_token.type in (TokenType.SINO, TokenType.ELSE):
            self.advance()
            self.expect(TokenType.LBRACE)
            
            else_body = []
            self.skip_newlines()
            
            while self.current_token and self.current_token.type != TokenType.RBRACE:
                stmt = self.parse_statement()
                if stmt:
                    else_body.append(stmt)
                self.skip_newlines()
            
            self.expect(TokenType.RBRACE)
        
        return IfStatement(condition, then_body, elif_parts, else_body)
    
    def parse_while(self):
        self.expect(TokenType.MIENTRAS, TokenType.WHILE)
        condition = self.parse_expression()
        self.expect(TokenType.LBRACE)
        
        body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return WhileLoop(condition, body)
    
    def parse_for(self):
        self.expect(TokenType.PARA, TokenType.FOR)
        
        var_name = self.expect(TokenType.IDENTIFIER).value
        index_var = None
        
        if self.current_token and self.current_token.type == TokenType.COMMA:
            self.advance()
            index_var = self.expect(TokenType.IDENTIFIER).value
        
        self.expect(TokenType.EN, TokenType.IN)
        iterable = self.parse_expression()
        
        self.expect(TokenType.LBRACE)
        
        body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return ForLoop(var_name, iterable, body, index_var)
    
    def parse_repeat(self):
        self.expect(TokenType.REPETIR, TokenType.REPEAT)
        times = self.parse_expression()
        
        index_var = None
        if self.current_token and self.current_token.type in (TokenType.COMO, TokenType.AS):
            self.advance()
            index_var = self.expect(TokenType.IDENTIFIER).value
        
        self.expect(TokenType.LBRACE)
        
        body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return RepeatLoop(times, body, index_var)
    
    def parse_loop(self):
        self.expect(TokenType.BUCLE, TokenType.LOOP)
        self.expect(TokenType.LBRACE)
        
        body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return InfiniteLoop(body)
    
    def parse_return(self):
        self.expect(TokenType.DAR, TokenType.GIVE)
        
        if self.current_token and self.current_token.type in (TokenType.NEWLINE, TokenType.RBRACE):
            return Return(None)
        
        value = self.parse_expression()
        return Return(value)
    
    def parse_match(self):
        self.expect(TokenType.COINCIDIR, TokenType.MATCH)
        value = self.parse_expression()
        self.expect(TokenType.LBRACE)
        
        cases = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            # Pattern
            pattern = self.parse_expression()
            self.expect(TokenType.ARROW)
            
            # Body puede ser una expresión o un bloque
            if self.current_token.type == TokenType.LBRACE:
                self.advance()
                body = []
                self.skip_newlines()
                
                while self.current_token and self.current_token.type != TokenType.RBRACE:
                    stmt = self.parse_statement()
                    if stmt:
                        body.append(stmt)
                    self.skip_newlines()
                
                self.expect(TokenType.RBRACE)
            else:
                body = [self.parse_expression()]
            
            cases.append((pattern, body))
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return MatchStatement(value, cases)
    
    def parse_try(self):
        self.expect(TokenType.INTENTAR, TokenType.TRY)
        self.expect(TokenType.LBRACE)
        
        try_body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                try_body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        self.expect(TokenType.CAPTURAR, TokenType.CATCH)
        
        except_var = self.expect(TokenType.IDENTIFIER).value
        self.expect(TokenType.LBRACE)
        
        except_body = []
        self.skip_newlines()
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            stmt = self.parse_statement()
            if stmt:
                except_body.append(stmt)
            self.skip_newlines()
        
        self.expect(TokenType.RBRACE)
        
        return TryExcept(try_body, except_var, except_body)
    
    def parse_assignment_or_expression(self):
        expr = self.parse_expression()
        
        if isinstance(expr, Identifier) and self.current_token:
            # Asignación con tipo
            if self.current_token.type == TokenType.COLON:
                self.advance()
                type_annotation = self.parse_type()
                self.expect(TokenType.ASSIGN)
                value = self.parse_expression()
                return Assignment(expr.name, value, type_annotation)
            
            # Asignación simple
            elif self.current_token.type == TokenType.ASSIGN:
                self.advance()
                value = self.parse_expression()
                return Assignment(expr.name, value)
            
            # Operadores de asignación compuesta
            elif self.current_token.type in (TokenType.PLUS_ASSIGN, TokenType.MINUS_ASSIGN, 
                                            TokenType.MULTIPLY_ASSIGN, TokenType.DIVIDE_ASSIGN):
                op = self.current_token.type
                self.advance()
                value = self.parse_expression()
                
                # Convertir += a = expr + value
                if op == TokenType.PLUS_ASSIGN:
                    value = BinaryOp(expr, '+', value)
                elif op == TokenType.MINUS_ASSIGN:
                    value = BinaryOp(expr, '-', value)
                elif op == TokenType.MULTIPLY_ASSIGN:
                    value = BinaryOp(expr, '*', value)
                elif op == TokenType.DIVIDE_ASSIGN:
                    value = BinaryOp(expr, '/', value)
                
                return Assignment(expr.name, value)
        
        return expr
    
    def parse_type(self):
        # Tipos simples o complejos
        type_name = self.expect(TokenType.IDENTIFIER).value
        
        # Tipos genéricos como lista[int]
        if self.current_token and self.current_token.type == TokenType.LBRACKET:
            self.advance()
            inner_type = self.parse_type()
            self.expect(TokenType.RBRACKET)
            return f"{type_name}[{inner_type}]"
        
        return type_name
    
    def parse_expression(self):
        return self.parse_logical_or()
    
    def parse_logical_or(self):
        left = self.parse_logical_and()
        
        while self.current_token and self.current_token.type in (TokenType.O, TokenType.OR):
            self.advance()
            right = self.parse_logical_and()
            left = BinaryOp(left, 'or', right)
        
        return left
    
    def parse_logical_and(self):
        left = self.parse_equality()
        
        while self.current_token and self.current_token.type in (TokenType.Y, TokenType.AND):
            self.advance()
            right = self.parse_equality()
            left = BinaryOp(left, 'and', right)
        
        return left
    
    def parse_equality(self):
        left = self.parse_comparison()
        
        while self.current_token and self.current_token.type in (TokenType.EQUAL, TokenType.NOT_EQUAL):
            op = '==' if self.current_token.type == TokenType.EQUAL else '!='
            self.advance()
            right = self.parse_comparison()
            left = BinaryOp(left, op, right)
        
        return left
    
    def parse_comparison(self):
        left = self.parse_range()
        
        while self.current_token and self.current_token.type in (TokenType.LESS, TokenType.GREATER,
                                                                 TokenType.LESS_EQUAL, TokenType.GREATER_EQUAL):
            op = self.current_token.value
            self.advance()
            right = self.parse_range()
            left = BinaryOp(left, op, right)
        
        return left
    
    def parse_range(self):
        left = self.parse_addition()
        
        if self.current_token and self.current_token.type == TokenType.RANGE:
            self.advance()
            right = self.parse_addition() if self.current_token.type != TokenType.ARROW else None
            return BinaryOp(left, '..', right)
        
        return left
    
    def parse_addition(self):
        left = self.parse_multiplication()
        
        while self.current_token and self.current_token.type in (TokenType.PLUS, TokenType.MINUS):
            op = self.current_token.value
            self.advance()
            right = self.parse_multiplication()
            left = BinaryOp(left, op, right)
        
        return left
    
    def parse_multiplication(self):
        left = self.parse_power()
        
        while self.current_token and self.current_token.type in (TokenType.MULTIPLY, TokenType.DIVIDE, TokenType.MODULO):
            op = self.current_token.value
            self.advance()
            right = self.parse_power()
            left = BinaryOp(left, op, right)
        
        return left
    
    def parse_power(self):
        left = self.parse_unary()
        
        if self.current_token and self.current_token.type == TokenType.POWER:
            self.advance()
            right = self.parse_power()  # Right associative
            return BinaryOp(left, '**', right)
        
        return left
    
    def parse_unary(self):
        if self.current_token and self.current_token.type in (TokenType.MINUS, TokenType.NO, TokenType.NOT):
            op = '-' if self.current_token.type == TokenType.MINUS else 'not'
            self.advance()
            operand = self.parse_unary()
            return UnaryOp(op, operand)
        
        # Operador @ para punteros
        if self.current_token and self.current_token.type == TokenType.AT:
            self.advance()
            operand = self.parse_unary()
            return PointerOp('deref', operand)
        
        return self.parse_postfix()
    
    def parse_postfix(self):
        expr = self.parse_primary()
        
        while self.current_token:
            # Acceso a miembro: obj.field
            if self.current_token.type == TokenType.DOT:
                self.advance()
                member = self.expect(TokenType.IDENTIFIER).value
                
                # Llamada a método: obj.method(args)
                if self.current_token and self.current_token.type == TokenType.LPAREN:
                    self.advance()
                    args = []
                    
                    while self.current_token and self.current_token.type != TokenType.RPAREN:
                        args.append(self.parse_expression())
                        if self.current_token and self.current_token.type == TokenType.COMMA:
                            self.advance()
                    
                    self.expect(TokenType.RPAREN)
                    expr = MethodCall(expr, member, args)
                else:
                    expr = MemberAccess(expr, member)
            
            # Acceso a índice: arr[index]
            elif self.current_token.type == TokenType.LBRACKET:
                self.advance()
                index = self.parse_expression()
                self.expect(TokenType.RBRACKET)
                expr = IndexAccess(expr, index)
            
            # Llamada a función: func(args)
            elif self.current_token.type == TokenType.LPAREN and isinstance(expr, Identifier):
                self.advance()
                args = []
                
                while self.current_token and self.current_token.type != TokenType.RPAREN:
                    args.append(self.parse_expression())
                    if self.current_token and self.current_token.type == TokenType.COMMA:
                        self.advance()
                
                self.expect(TokenType.RPAREN)
                expr = FunctionCall(expr.name, args)
            
            else:
                break
        
        return expr
    
    def parse_primary(self):
        # Números
        if self.current_token.type == TokenType.NUMBER:
            value = self.current_token.value
            self.advance()
            return NumberLiteral(value)
        
        # Strings
        if self.current_token.type == TokenType.STRING:
            value = self.current_token.value
            self.advance()
            return StringLiteral(value)
        
        # Booleanos
        if self.current_token.type in (TokenType.VERDADERO, TokenType.TRUE):
            self.advance()
            return BoolLiteral(True)
        
        if self.current_token.type in (TokenType.FALSO, TokenType.FALSE):
            self.advance()
            return BoolLiteral(False)
        
        # None/nada
        if self.current_token.type in (TokenType.NADA, TokenType.NONE):
            self.advance()
            return NoneLiteral()
        
        # Listas
        if self.current_token.type == TokenType.LBRACKET:
            return self.parse_list()
        
        # Mapas
        if self.current_token.type == TokenType.LBRACE:
            return self.parse_map()
        
        # Paréntesis
        if self.current_token.type == TokenType.LPAREN:
            self.advance()
            expr = self.parse_expression()
            self.expect(TokenType.RPAREN)
            return expr
        
        # Identificadores (pueden ser variables o instanciación de shapes)
        if self.current_token.type == TokenType.IDENTIFIER:
            name = self.current_token.value
            self.advance()
            
            # Instanciación de shape: Shape{field: value}
            if self.current_token and self.current_token.type == TokenType.LBRACE:
                self.advance()
                field_values = {}
                
                while self.current_token and self.current_token.type != TokenType.RBRACE:
                    field_name = self.expect(TokenType.IDENTIFIER).value
                    self.expect(TokenType.COLON)
                    field_value = self.parse_expression()
                    field_values[field_name] = field_value
                    
                    if self.current_token and self.current_token.type == TokenType.COMMA:
                        self.advance()
                
                self.expect(TokenType.RBRACE)
                return ShapeInstantiation(name, field_values)
            
            return Identifier(name)
        
        raise SyntaxError(f"Token inesperado: {self.current_token}")
    
    def parse_list(self):
        self.expect(TokenType.LBRACKET)
        elements = []
        
        while self.current_token and self.current_token.type != TokenType.RBRACKET:
            elements.append(self.parse_expression())
            if self.current_token and self.current_token.type == TokenType.COMMA:
                self.advance()
        
        self.expect(TokenType.RBRACKET)
        return ListLiteral(elements)
    
    def parse_map(self):
        self.expect(TokenType.LBRACE)
        pairs = []
        
        while self.current_token and self.current_token.type != TokenType.RBRACE:
            # Puede ser un mapa o un bloque de código
            # Si vemos un identificador seguido de :, es un mapa
            if self.current_token.type == TokenType.IDENTIFIER:
                next_tok = self.peek()
                if next_tok and next_tok.type == TokenType.COLON:
                    key_name = self.current_token.value
                    self.advance()
                    self.expect(TokenType.COLON)
                    value = self.parse_expression()
                    pairs.append((StringLiteral(key_name), value))
                    
                    if self.current_token and self.current_token.type == TokenType.COMMA:
                        self.advance()
                    continue
            
            # Si no es mapa, probablemente es un error o bloque de código
            break
        
        self.expect(TokenType.RBRACE)
        return MapLiteral(pairs)