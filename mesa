# -*- coding: utf-8 -*-
"""Mesa Language v2.2.0 - LA CABRA"""
import sys
import os

# --- ARREGLO PARA COMANDO GLOBAL ---
# os.path.realpath resuelve el enlace simbólico para encontrar la carpeta real
MESA_DIR = os.path.dirname(os.path.realpath(__file__))
if MESA_DIR not in sys.path:
    sys.path.insert(0, MESA_DIR)
# -----------------------------------

VERSION = "2.2.0"

